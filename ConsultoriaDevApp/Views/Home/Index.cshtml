@model IEnumerable<ConsultoriaDevApp.Models.Servico>
@{
    ViewData["Title"] = "Serviços";
}

<div class="container">
    <div class="hero-section">
        <span class="eyebrow">// desenvolvimento sob demanda</span>
        <h1>Resolva seu problema<br>com quem <em>entende de código</em></h1>
        <p class="lead">Escolha o serviço, envie sua solicitação e nosso time entra em contato em até 12h.</p>
    </div>

    <div class="hero-divider"></div>

    <div class="row g-4 mb-5">
        @foreach (var servico in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card service-card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="service-icon">
                            <i class="bi bi-terminal"></i>
                        </div>
                        <h5 class="card-title">@servico.Nome</h5>
                        <p class="card-text flex-grow-1">@servico.Descricao</p>
                        <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
                            <span class="tag-tempo">
                                <i class="bi bi-clock"></i> @servico.TempoResposta
                            </span>
                            <span class="preco-label">R$&nbsp;@servico.Preco.ToString("N2")</span>
                        </div>
                        <button class="btn btn-primary w-100"
                                data-bs-toggle="modal"
                                data-bs-target="#modalSolicitacao"
                                data-servico-id="@servico.Id"
                                data-servico-nome="@servico.Nome">
                            Contratar serviço
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalSolicitacao" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header px-4 pt-4 pb-3">
                <div>
                    <h5 class="modal-title fw-semibold mb-0">Solicitar serviço</h5>
                    <p class="mb-0" id="modalServicoNome"
                       style="font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-top:4px"></p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-check-circle-fill"></i>
                    Seu pedido será analisado e você receberá resposta por e-mail.
                </div>
                <form asp-controller="Solicitacao" asp-action="Criar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ServicoId" id="inputServicoId" />
                    <div class="mb-3">
                        <label class="form-label">Seu nome</label>
                        <input type="text" name="NomeCliente" class="form-control" placeholder="Nome completo" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Seu e-mail</label>
                        <input type="email" name="EmailCliente" class="form-control" placeholder="email@exemplo.com" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Observação <span style="color:var(--text-dim)">(opcional)</span></label>
                        <textarea name="Observacao" class="form-control" rows="3" placeholder="Descreva brevemente..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-send me-2"></i>Enviar solicitação
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalSolicitacao').addEventListener('show.bs.modal', function(e) {
            const btn = e.relatedTarget;
            document.getElementById('inputServicoId').value = btn.dataset.servicoId;
            document.getElementById('modalServicoNome').textContent = '// ' + btn.dataset.servicoNome;
        });
    </script>
}