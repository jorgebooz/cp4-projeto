<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ConsultoriaDev</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container d-flex align-items-center gap-4">

            <a class="navbar-brand" href="/">
                <span class="brand-icon"><i class="bi bi-code-slash"></i></span>
                Consultoria<span class="brand-accent">Dev</span>
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="bi bi-list text-white fs-5"></i>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-grid-1x2 me-1"></i>Serviços</a>
                    </li>
                    @if (User.IsInRole("TechLider") || User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/admin"><i class="bi bi-kanban me-1"></i>Painel</a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item d-flex align-items-center gap-2">
                            <span class="badge-role">
                                @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                            </span>
                            <span style="font-size:13px; color:var(--text-muted)">@User.Identity.Name</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-box-arrow-right me-1"></i>Sair
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a href="/Auth/Login" class="btn btn-sm btn-primary">
                                <i class="bi bi-person-lock me-1"></i>Login
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p>&copy; @DateTime.Now.Year ConsultoriaDev — Todos os direitos reservados</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>